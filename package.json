{
  "name": "mi_quantify",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "pnpm tauri build --target universal-apple-darwin",
    "build:mac-arm": "pnpm tauri build --target aarch64-apple-darwin",
    "build:mac-intel": "pnpm tauri build --target x86_64-apple-darwin",
    "build:windows": "pnpm tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "pnpm tauri build --target x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "lightweight-charts": "^5.1.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.99.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
