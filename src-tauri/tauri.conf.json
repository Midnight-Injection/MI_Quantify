{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MI Quantify",
  "version": "0.1.0",
  "identifier": "io.github.midnight",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1428",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MI Quantify",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 780,
        "center": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
