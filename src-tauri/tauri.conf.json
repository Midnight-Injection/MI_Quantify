{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MI Quantify",
  "version": "0.1.2",
  "identifier": "io.github.midnight",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1428",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MI Quantify",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 780,
        "center": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "resources": [],
    "externalBin": ["binaries/mi-quantify-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Midnight Injection",
    "shortDescription": "MI Quantify - AI stock research workstation",
    "longDescription": "MI Quantify is an AI-driven stock research workstation for market scanning, single-stock diagnosis, strategy evaluation and live monitoring.",
    "category": "Finance",
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "tsp": false,
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwOTRENTJFN0EyNDc5QzcKUldUSGVTUjZMdFdVVUVwNGdDTkhwWFdpbHF5V0xQNi9QYzFiYVRaRUJqVTFxanFPaUd4b2N1OTUK",
      "endpoints": [
        "https://github.com/Midnight-Injection/MI_Quantify/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
